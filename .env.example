# 必填：OpenAI API 密钥
LLM_API_KEY=

# 可选：默认使用 OpenAI Responses API
LLM_BASE_URL=https://api.openai.com/v1

# 可选：默认使用 GPT-5.5
LLM_MODEL=gpt-5.5

# 可选：Pro 解锁码签名密钥。配置后 /api/license 才能验证解锁码。
# 发码方式：LICENSE_SECRET=xxx node scripts/generate-license.mjs "用户邮箱"
LICENSE_SECRET=

# 可选：付款链接（如 Stripe Payment Link / 收款码页面）。未配置时页面提示人工渠道。
PAYMENT_URL=
